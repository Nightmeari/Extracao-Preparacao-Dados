S_warmStartDocumentLoader = KX_kixApp.getWarmStartDocumentLoader(); DOCS_cseBlobArtifactsHolder = KX_kixApp.getCseBlobArtifactsHolder(); DOCS_initialLoadTiming = KX_kixApp.getInitialLoadTiming(); KX_getLatencyStats = function() {return KX_kixApp.getPerformanceManager().getInitialLoadStats();}; KX_resize = function() {KX_kixApp.resize();}; _docs_annotate_getAnnotatedText = function(id) {return KX_kixApp.getAnnotatedText(id);};}KX_startKix(); DOCS_initialLoadTiming.setTime('eac');</script><script nonce="-Vde9ddkgH_eHruRUDjvBw">DOCS_warmStartDocumentLoader.startLoad( 212.0 ,'8ZB3xzVMsDwDNA', 45.0 , 13.0 ,[45,""], null , null ); var DOCS_modelChunkLoadStart; var DOCS_modelChunkParseStart; var DOCS_modelChunk;</script><script nonce="-Vde9ddkgH_eHruRUDjvBw">DOCS_modelChunkParseStart = new Date().getTime();</script><script nonce="-Vde9ddkgH_eHruRUDjvBw">DOCS_modelChunk = {"chunk":[{"ty":"is","ibi":1,"s":"ESTRATÉGIA EMPREENDEDORA\n\nLISTA ACs\n\nIDENTIFICAÇÃO DOS INTEGRANTES DO GRUPO\nNome dos integrantes do grupo.\n\nEXPLORAÇÃO DE FRUSTRAÇÕES \nCada grupo deve identificar duas frustrações reais, que já tenham vivido pessoalmente, nos últimos 6 meses.\nFrustração 1 (contexto específico):\nO que aconteceu (problema)?\nOnde aconteceu? \nQuando? \nIsso acontece com que frequência? \nQuem do grupo já vivenciou? \nNível de dor (1–10)?\nFrustração 2 (contexto específico):\nO que aconteceu (problema)?\nOnde aconteceu? \nQuando? \nIsso acontece com que frequência? \nQuem do grupo já vivenciou? \nNível de dor (1–10)?\n\nANÁLISE DA CAUSA RAIZ\nCada grupo deve investigar a causa raiz das duas frustrações identificadas no exercício anterior.\nFrustração 1:\nPor que isso acontece? (vá além da primeira resposta superficial)\nQuem é impactado (perfil)?\nSituação em que sofre essa frustração?\nQue soluções já existem para esse problema?\nPor que ainda não resolveram completamente?\nFrustração 2:\nPor que isso acontece? (vá além da primeira resposta superficial)\nQuem é impactado (perfil)?\nSituação em que sofre essa frustração?\nQue soluções já existem para esse problema?\nPor que ainda não resolveram completamente?\n\nDESCRIÇÃO DA FRUSTRAÇÃO\nPara cada frustração, complete a frase:\nFrustração 1:\n“Acreditamos que ________ (perfil) sofre com ________ (problema específico) porque ________ (causa raiz). As soluções atuais falham porque ________.”\nFrustração 2:\n“Acreditamos que ________ (perfil) sofre com ________ (problema específico) porque ________ (causa raiz). As soluções atuais falham porque ________.”\n"},{"ty":"as","st":"document","si":0,"ei":0,"sm":{"ds_fpo":true,"ds_pw":595.4399999999999,"ds_lhs":1,"ds_ulhfl":false,"ds_ph":841.68}},{"ty":"ae","et":"list","id":"kix.nkpwftwk3m48","epm":{"le_nb":{"nl_4":{"b_gf":"%4.","b_ts":{"ts_un":false,"ts_un_i":false,"ts_sc":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#000000","clr_type":0},"ts_st_i":true,"ts_bgc2":{"hclr_color":null,"clr_type":0},"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":false,"ts_va":"nor","ts_bd_i":true,"ts_va_i":true,"ts_fs":11.0,"ts_ff":"Arial","ts_st":false,"ts_bd":false,"ts_fgc2_i":true,"ts_sc_i":true,"ts_tw":400},"b_ifl":198.0,"b_gs":"","b_a":0,"b_sn":1,"b_gt":13,"b_il":216.0},"nl_3":{"b_gf":"%3.","b_ts":{"ts_un":false,"ts_un_i":false,"ts_sc":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#000000","clr_type":0},"ts_st_i":true,"ts_bgc2":{"hclr_color":null,"clr_type":0},"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":false,"ts_va":"nor","ts_bd_i":true,"ts_va_i":true,"ts_fs":11.0,"ts_ff":"Arial","ts_st":false,"ts_bd":false,"ts_fgc2_i":true,"ts_sc_i":true,"ts_tw":400},"b_ifl":162.0,"b_gs":"","b_a":0,"b_sn":1,"b_gt":10,"b_il":180.0},"nl_2":{"b_gf":"%2.","b_ts":{"ts_un":false,"ts_un_i":false,"ts_sc":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#000000","clr_type":0},"ts_st_i":true,"ts_bgc2":{"hclr_color":null,"clr_type":0},"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":false,"ts_va":"nor","ts_bd_i":true,"ts_va_i":true,"ts_fs":11.0,"ts_ff":"Arial","ts_st":fal