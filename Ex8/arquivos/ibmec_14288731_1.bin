r().getInitialLoadStats();}; KX_resize = function() {KX_kixApp.resize();}; _docs_annotate_getAnnotatedText = function(id) {return KX_kixApp.getAnnotatedText(id);};}KX_startKix(); DOCS_initialLoadTiming.setTime('eac');</script><script nonce="WkOc-jdv2HOz4AhxeShEvA">DOCS_warmStartDocumentLoader.startLoad( 322.0 ,'C4EUNZIFCF0tHQ', 45.0 , 13.0 ,[45,""], null , null ); var DOCS_modelChunkLoadStart; var DOCS_modelChunkParseStart; var DOCS_modelChunk;</script><script nonce="WkOc-jdv2HOz4AhxeShEvA">DOCS_modelChunkParseStart = new Date().getTime();</script><script nonce="WkOc-jdv2HOz4AhxeShEvA">DOCS_modelChunk = {"chunk":[{"ty":"is","ibi":1,"s":"Engenharia de Dados\n\nLista ACs\n\nEntrevista:\nCada grupo representa uma empresa:\nDefinir o segmento de mercado da empresa.\nClínica Veterinária\nHotel\nLivraria\nLocadora de Carros\nDefinir o nome da empresa.\nDefinir quais produtos e/ou serviços a empresa fornece.\nDiscutir quais requisitos (recursos) o sistema de vendas da sua empresa necessita.\nCriar uma entrevista, com 10 perguntas, para coletar os requisitos do sistema.  \nResultado esperado: lista de perguntas da entrevista.\n\nAnálise de Requisitos:\nRealizar a entrevista com o outro grupo.\nRealizar a análise do mini-mundo da empresa do outro grupo.\nIdentificar requisitos do sistema.\nIdentificar regras de negócio do sistema.\nIdentificar informações que o sistema deve fornecer.\nResultado esperado: lista de requisitos (com dados), regras de negócio e informações a serem geradas pelo sistema.\n\nModelo Entidade-Relacionamento (MER)\nCom base no resultado gerado no exercício de análise de requisitos (lista de requisito com dados, regras de negócio e informações que o sistema deve gerar), elaborar o Modelo Entidade-Relacionamento (MER) do sistema:\nIdentificar todas as entidades do sistema.\nDefinir os atributos de cada entidade, indicando o tipo do atributo.\nDefinir os relacionamentos entre as entidades, nomeando cada um.\nEstabelecer a cardinalidade entre os relacionamentos.\nResultado esperado: MER em formato textual.\n\nDiagrama Entidade-Relacionamento (DER)\nCom base no resultado gerado no exercício de criação do Modelo Entidade-Relacionamento, elaborar o Diagrama Entidade-Relacionamento (MER) do sistema, utilizando a notação de Peter Chen.\nRepresentar todas as entidades do sistema.\nRepresentar os atributos de cada entidade, indicando o tipo do atributo.\nRepresentar os relacionamentos entre as entidades, nomeando cada um.\nRepresentar a cardinalidade e participação entre os relacionamentos.\nResultado esperado: DER utilizando a notação de Chen.\n\n\nDiagrama Entidade-Relacionamento (DER)\nCom base no resultado gerado no exercício de criação do Diagrama Entidade-Relacionamento Conceitual (Peter Chen), elaborar o Diagrama Entidade-Relacionamento (MER) do sistema no nível lógico, utilizando a notação Crow´s Foot.\nRepresentar todas as entidades do sistema.\nRepresentar os atributos de cada entidade, indicando o tipo do atributo.\nRepresentar os relacionamentos entre as entidades, nomeando cada um.\nRepresentar a cardinalidade.\nResultado esperado: DER Lógico utilizando a notação de Crow´s Foot.\n\nUma escola de cursos livres controla suas matrículas em uma única planilha. Veja como os dados estão armazenados atualmente:\nAplicar a 1FN\nAplicar a 2FN\nAplicar a 3FN\n*\nResultado Esperado: Estrutura do Banco de dados normalizada.\n\nCriar o Projeto Físico (DDL) da sua solução.​\nTodas as tabelas, atributos e relacionamentos identificados no DER Lógico (Crow\u0027s Foot).​\nResultado Esperado: Estrutura Física do Banco – SQL de criação de todas as tabelas.​\n\nApós a criação do banco de dados da loja, você recebeu algumas planilhas da empresa com dados reais que precisam ser cadastrados no sistema.\nInserir essas informações no banco, respeitando:\nA estrutura das tabelas.\nOs relacionamentos entre elas.\nA ordem correta de inserção.\nResultado Esperado: Backup do BD loja com a estrutura e dados cadastrados.\n\nApós cadastrar os dados, a você fazer as seguintes consultas para validar os dados:\nListagem geral:\nListar todos os produtos.\nListar todos os clientes.\nListar todos os pedidos.\nSeleção específica:\nListar nome e valor dos produtos.\nListe apenas o nome e email dos clientes.\nSeleção com filtros:\nListe os produtos com valor maior que 500.\nListe os produtos com estoque menor que 10.\nListe os pedidos de um cliente específico.\nListe produtos com valor entre 500 e 3000.\nListe os clientes cujo nome contém “Faria”.\nAtualização:\nAtualize o valor do produto Ventilador para 350.\nAtualize o estoque do Cooktop para 50.\nAtualize, ao mesmo tempo, o valor e o estoque da Batedeira para 420 e 37, respectivamente.\nAtualize o email do Eduardo Pires para dudu@gmail.com.\n"},{"ty":"as","st":"document","si":0,"ei":0,"sm":{"ds_fpo":true,"ds_pw":595.4399999999999,"ds_lhs":1,"ds_ulhfl":false,"ds_ph":841.68}},{"ty":"ae","et":"inline","id":"kix.a8f5zjfr7ofk","epm":{"ee_eo":{"eo_bo":{"ln_s":0,"ln_w":0.0,"ln_c2":{"hclr_color":"#000000","clr_type":0}},"i_pid":null,"eo_mb":9.0,"i_ht":107.0,"eo_rtdf":{"rdf_ft":0},"eo_ml":9.0,"eo_mr":9.0,"eo_ad":null,"i_cid":"s-blob-v1-IMAGE-b2_YbLgydFE","i_cont":0.0,"eo_mt":9.0,"eo_type":0,"eo_lco":{"lc_oi":"","lc_cs":"","lc_ct":0,"lc_sci":"","lc_srk":""},"i_wth":697.8897637795277,"eo_at":null,"i_iwc":{"iwc_w":false},"eo_hb":false,"eo_rtd":"","i_crop":{"crop_oxr":0.0,"crop_oyr":0.0,"crop_rot":0.0,"crop_hr":1.0,"crop_wr":1.0},"i_iw":false,"i_rot":0.0,"i_clst":{"cv":{"op":"set","opValue":[]}},"i_bri":0.0,"i_msct":0,"i_src":"","i_opa":1.0}}},{"ty":"ae","et":"list","id":"kix.c9eznovizf7u","epm":{"le_nb":{"nl_4":{"b_gf":"%0.%1.%2.%3.%4.","b_ts":{"ts_un":false,"ts_un_i":false,"ts_sc":false,"ts_it_i":true,"ts_fgc2":{"hclr_color":"#000000","clr_type":0},"ts_st_i":true,"ts_bgc2":{"hclr_color":null,"clr_type":0},"ts_fs_i":true,"ts_ff_i":true,"ts_bgc2_i":true,"ts_it":false,"ts_va":"nor","ts_bd_i":true,"ts_va_i":true,"ts_fs":11.0,"ts_ff":"Arial","ts_st":false,"ts_bd":false,"ts_f